{
  "openapi": "3.0.2",
  "info": {
    "title": "Listify API",
    "description": "API built with Express - Managed by CloudWapp Technologies (India)",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "security": [],
  "paths": {
    "/global/upload": {
      "post": {
        "summary": "Upload File",
        "description": "Uploads a file to the specified folder. The folder name should be passed as a query parameter.",
        "tags": [
          "GLOBAL"
        ],
        "parameters": [
          {
            "name": "folder",
            "in": "query",
            "description": "Folder where the file should be uploaded (e.g., profile, additionalImg, etc.)",
            "required": true,
            "schema": {
              "type": "string",
              "example": "profile"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "The file to upload"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Request successful"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/global/deleteFile/{file_path}": {
      "delete": {
        "summary": "Delete File",
        "tags": [
          "GLOBAL"
        ],
        "parameters": [
          {
            "name": "file_path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "example": "assets/category/file-1740720238602-939068402.jpg"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Request successful"
          },
          "400": {
            "description": "Bad request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/admin/login": {
      "post": {
        "summary": "Login Admin",
        "tags": [
          "ADMIN"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email_address": {
                    "type": "string",
                    "default": "admin@cloudwapp.com"
                  },
                  "password": {
                    "type": "string",
                    "default": "12345"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Request successful"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/user/register": {
      "post": {
        "summary": "Register user",
        "tags": [
          "USER"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/AcceptLanguage"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "email",
                  "password"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "Jane Doe"
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 6
                  },
                  "country_code": {
                    "type": "string",
                    "example": "+91"
                  },
                  "phone_number": {
                    "type": "string",
                    "example": "9876543210"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "individual",
                      "group"
                    ]
                  },
                  "bio": {
                    "type": "string"
                  },
                  "rate": {
                    "type": "number"
                  },
                  "location": {
                    "type": "string"
                  },
                  "age": {
                    "type": "integer"
                  },
                  "interests": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Registered"
          },
          "400": {
            "description": "Bad request"
          },
          "409": {
            "description": "Email or phone already exists"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/user/login": {
      "post": {
        "summary": "Login with email and password",
        "tags": [
          "USER"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/AcceptLanguage"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string"
                  },
                  "fcm_token": {
                    "type": "string",
                    "description": "FCM token for push notifications"
                  },
                  "device_id": {
                    "type": "string",
                    "description": "Stable device identifier (recommended; used with logout)"
                  },
                  "device_token": {
                    "type": "string",
                    "description": "Alias for device_id if client uses this name"
                  },
                  "device_type": {
                    "type": "string",
                    "description": "Platform e.g. ios, android, web",
                    "example": "android"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Invalid credentials"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/user/logout": {
      "post": {
        "summary": "Logout",
        "tags": [
          "USER"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/AcceptLanguage"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "device_id": {
                    "type": "string",
                    "default": ""
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "Bad request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "parameters": {
      "AcceptLanguage": {
        "name": "Accept-Language",
        "in": "header",
        "description": "Preferred language (e.g., en, ar, hi)",
        "required": false,
        "schema": {
          "type": "string",
          "default": "en",
          "example": "en"
        }
      }
    }
  }
}